# ================================================================
# Manobi Sentinel — Variables de Entorno
# Copia este archivo a `.env` y completa los valores antes de levantar la pila.
# NUNCA comitees el archivo .env real al repositorio.
# ================================================================

# ---- General ----
PROJECT_NAME=manobi-sentinel
TZ=America/Bogota
NODE_ENV=production
LOG_LEVEL=info

# Dominio o IP pública del servidor (sin protocolo). Ej: sentinel.parques.gov.co o 192.168.50.5
PUBLIC_HOST=192.168.50.5
PUBLIC_URL=https://192.168.50.5

# ---- Rutas en el host (discos montados) ----
HOST_DATA_POSTGRES=/opt/manobi/postgres
HOST_DATA_MINIO=/opt/manobi/minio
HOST_DATA_TILES=/opt/manobi/tiles
HOST_DATA_MONITORING=/opt/manobi/monitoring

# ---- PostgreSQL / PostGIS ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=manobi
POSTGRES_USER=manobi
POSTGRES_PASSWORD=CHANGE_ME_strong_password_postgres
DATABASE_URL=postgres://manobi:CHANGE_ME_strong_password_postgres@postgres:5432/manobi

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_password_redis
REDIS_URL=redis://:CHANGE_ME_strong_password_redis@redis:6379

# ---- MinIO (S3 compatible on-premise) ----
MINIO_ROOT_USER=manobi_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password_minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_REPORTES=reportes
MINIO_BUCKET_UPLOADS=uploads
MINIO_USE_SSL=false

# ---- Admin inicial (se crea al primer arranque si no existe) ----
ADMIN_EMAIL=admin@manobi.local
ADMIN_PASSWORD=ChangeMe12345!

# ---- API NestJS ----
API_PORT=3000
JWT_ACCESS_SECRET=CHANGE_ME_random_64_bytes_for_access_token
JWT_REFRESH_SECRET=CHANGE_ME_random_64_bytes_for_refresh_token
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
CORS_ORIGIN=https://192.168.50.5

# ---- Microservicio IA (FastAPI) ----
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_PORT=8000

# ---- GeoServer ----
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=CHANGE_ME_strong_password_geoserver

# ---- pg_tileserv / pg_featureserv ----
PG_TILESERV_PORT=7800
PG_FEATURESERV_PORT=7900

# ---- TileServer GL ----
TILESERVER_PORT=8080

# ---- Postfix (SMTP relay institucional) ----
SMTP_HOST=postfix
SMTP_PORT=25
SMTP_FROM=alertas@parques.gov.co
SMTP_RELAY_HOST=                 # ej: smtp.parques.gov.co (vacío = sin relay)
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=
SMTP_RELAY_PASSWORD=
SMTP_RELAY_USE_TLS=true

# ---- IDEAM ----
IDEAM_MODE=simulado              # simulado | real
IDEAM_API_URL=http://bart.ideam.gov.co/cliciu/
IDEAM_POLL_INTERVAL_MIN=30

# ---- Monitoreo ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password_grafana
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=720h              # 30 días

# ---- Notificaciones ----
NOTIFY_EMAIL_OPERADORES=ops@parques.gov.co,sala@parques.gov.co
WEBHOOK_WHATSAPP_URL=
WEBHOOK_SMS_URL=
